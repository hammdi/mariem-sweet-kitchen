# ─────────────────────────────────────────────────────────────
# Template .env.production — COPIER en .env.production et remplir
# ─────────────────────────────────────────────────────────────
# NE JAMAIS committer le vrai .env.production.
# NE JAMAIS partager ces secrets dans un chat, un screenshot, un ticket.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ─── MongoDB Atlas ──────────────────────────────────────────
# ⚠️  URL-encoder tout caractere special du mot de passe (@, :, /, ?)
# @ → %40   :  → %3A   /  → %2F   ?  → %3F
# Exemple si mdp = "Mariem@Kitchen2026" → "Mariem%40Kitchen2026"
MONGODB_URI=

# ─── Sécurité JWT (OBLIGATOIRE, min 32 caractères) ──────────
# Generer : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Admin seed (OBLIGATOIRE si tu lances le seed) ──────────
# Utilise UNIQUEMENT lors du seed initial — change-le via l'admin apres login
# Generer : openssl rand -base64 20
ADMIN_EMAIL=admin@mariemkitchen.com
ADMIN_PASSWORD=

# ─── CORS (domaine de production uniquement) ────────────────
CORS_ORIGIN=https://mariem.hamdikbaier.dev

# ─── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ─── Upload ─────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ─── Telegram Bot (notifications commandes) ─────────────────
# Creer le bot via @BotFather, recuperer chat_id via @userinfobot
# ⚠️  Mariem DOIT envoyer /start au bot au moins une fois sinon le bot ne peut pas l'ecrire
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── IA — Google Gemini (tier gratuit, provider primaire) ───
# Console : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── IA — Groq (tier gratuit, provider de fallback) ─────────
# Console : https://console.groq.com/keys
GROQ_API_KEY=
