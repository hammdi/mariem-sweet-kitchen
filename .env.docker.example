# Docker Compose environment variables
# Copy this file to .env.docker and fill in real values
# Usage: cp .env.docker.example .env.docker

# MongoDB
MONGO_USERNAME=admin
MONGO_PASSWORD=CHANGE_ME_strong_password_here
MONGO_DATABASE=mariem_kitchen

# Backend
NODE_ENV=production
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@mariemkitchen.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=1000

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3001/api
