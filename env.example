# Configuration de l'application
NODE_ENV=development
PORT=3001

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/mariem_kitchen
MONGODB_TEST_URI=mongodb://localhost:27017/mariem_kitchen_test

# JWT Configuration — OBLIGATOIRE: générer une valeur aléatoire forte
# ex: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880 # 5MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Frontend Configuration (Vite)
VITE_API_URL=http://localhost:3001/api

# Admin Configuration (seed uniquement, dev)
# Définir un mot de passe fort avant de lancer le seed en staging/prod
ADMIN_EMAIL=admin@mariemkitchen.com
ADMIN_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Telegram (notifications de commande)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
